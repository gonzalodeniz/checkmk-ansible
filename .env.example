# URL base de Checkmk, sin /cmk/check_mk/login.py
CMK_URL=http://localhost:8080
CMK_SITE=cmk
CMK_USERNAME=cmkadmin
CMK_PASSWORD=change-me

# false para un Checkmk local HTTP o con certificado no verificable.
CMK_VERIFY_TLS=false

# Tags de host que controlan el inventario. Todo atributo que comience por
# CMK_GROUP_ATTRIBUTE_PREFIX crea un grupo con su valor: ansible_linux se
# convierte en linux y ansible_dev en dev.
CMK_ENABLE_ATTRIBUTE=tag_ansible_enable
CMK_ENABLE_VALUE=ansible_enable
CMK_GROUP_ATTRIBUTE_PREFIX=tag_ansible_group_
